# LLM Provider Configuration
# Supports any OpenAI-compatible API (GPT, DeepSeek, Qwen, etc.)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# External Data APIs (optional — falls back to mock data if not set)
FRED_API_KEY=your-fred-api-key-here
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# yfinance does not require an API key

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Scheduled Jobs (AI News Digest) ────────────────────────────────
# Generate a strong token: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Required in the Authorization: Bearer ... header when calling POST /api/jobs/*
JOB_TOKEN=replace-with-random-string

# Gmail SMTP — use an App Password, NOT your Gmail account password
# Create an App Password at: https://myaccount.google.com/apppasswords
SMTP_USER=strangeromo@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DIGEST_RECIPIENT=xujz4@lenovo.com
